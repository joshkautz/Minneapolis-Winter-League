rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user's email is verified
    function isEmailVerified() {
      return request.auth != null && request.auth.token.email_verified == true;
    }
    //////////////////////////////////////////////////////////////////////////////
    // STRIPE INTEGRATION - Secure payment data access
    //////////////////////////////////////////////////////////////////////////////

    // STRIPE: Custom Stripe integration for payments
    match /stripe/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;

      // Checkout sessions: Read-only (created by createStripeCheckout function)
      // No frontend write access needed - all checkout creation goes through callable function
      match /checkouts/{id} {
        allow read: if isAuthenticated() && request.auth.uid == uid;
        allow write: if false; // Functions only
      }

      // Payments: Read-only for users (created by Stripe webhook)
      match /payments/{id} {
        allow read: if isAuthenticated() && request.auth.uid == uid;
        allow write: if false; // Webhook only
      }
    }

    //////////////////////////////////////////////////////////////////////////////
    // DROPBOX SIGN - Waiver signature tracking
    //////////////////////////////////////////////////////////////////////////////

    // DROPBOX: Per-user waiver documents
    match /dropbox/{uid} {
      allow read: if isAuthenticated() && request.auth.uid == uid;

      // Waivers: Read-only for users (created by onPaymentCreated, updated by webhook)
      match /waivers/{id} {
        allow read: if isAuthenticated() && request.auth.uid == uid;
        allow write: if false; // Functions only (onPaymentCreated, dropboxSignWebhook)
      }
    }

    match /seasons/{seasonId} {
      allow read: if true;
      allow create: if false; // Force use of Functions
      allow update: if false; // Force use of Functions
      allow delete: if false; // Force use of Functions
    }
    
    match /games/{gameId} {
      allow read: if true;
      allow create: if false; // Force use of Functions
      allow update: if false; // Force use of Functions
      allow delete: if false; // Force use of Functions
    }
    
    match /teams/{teamId} {
      allow read: if true;
      allow create: if false; // Use createTeamViaFunction
      allow update: if false; // Use editTeamViaFunction, manageTeamPlayerViaFunction
      allow delete: if false; // Use deleteTeamViaFunction

      // Per-season participation subdocuments
      match /teamSeasons/{seasonId} {
        allow read: if true;
        allow write: if false; // Functions only

        // Pure membership join, one doc per (team, season, player)
        match /roster/{playerId} {
          allow read: if true;
          allow write: if false; // Functions only
        }
      }
    }

    match /players/{playerId} {
      allow read: if true;
      allow create: if false; // Use createPlayerViaFunction
      allow update: if false; // Use updatePlayerViaFunction
      allow delete: if false; // Use deletePlayerViaFunction

      // Per-season participation subdocuments (paid, signed, banned, captain, team)
      match /playerSeasons/{seasonId} {
        allow read: if true;
        allow write: if false; // Functions only
      }
    }
    
    match /offers/{offerId} {
      allow read: if true;
      allow create: if false; // Use createOfferViaFunction
      allow update: if false; // Use updateOfferStatusViaFunction
      allow delete: if false; // Manual process
    }

    match /news/{newsId} {
      allow read: if true; // Public read access for all users
      allow create: if false; // Use createNewsViaFunction (future)
      allow update: if false; // Use updateNewsViaFunction (future)
      allow delete: if false; // Use deleteNewsViaFunction (future)
    }

    match /rankings/{playerId} {
      allow read: if true;
      allow create: if false; // Functions only
      allow update: if false; // Functions only
      allow delete: if false; // Functions only
    }
    
    match /rankings-history/{snapshotId} {
      allow read: if true;
      allow create: if false; // Functions only
      allow update: if false; // Functions only
      allow delete: if false; // Functions only
    }
    
    match /rankings-calculations/{calculationId} {
      allow read: if true;
      allow create: if false; // Functions only
      allow update: if false; // Functions only
      allow delete: if false; // Functions only
    }

    match /badges/{badgeId} {
      allow read: if true;
      allow create: if false; // Use createBadgeViaFunction
      allow update: if false; // Use updateBadgeViaFunction
      allow delete: if false; // Use deleteBadgeViaFunction
    }

    match /teams/{teamId}/badges/{badgeId} {
      allow read: if true;
      allow create: if false; // Use awardBadgeViaFunction
      allow update: if false; // Badges are immutable once awarded
      allow delete: if false; // Use revokeBadgeViaFunction
    }

    // Collection-group access. Firestore rules require an explicit recursive
    // match for `collectionGroup()` queries even when the direct subcollection
    // path is already allowed above. These mirror the read posture of the
    // direct-path rules; writes stay locked behind Functions.
    match /{path=**}/teamSeasons/{seasonId} {
      allow read: if true;
      allow write: if false; // Functions only
    }

    match /{path=**}/playerSeasons/{seasonId} {
      allow read: if true;
      allow write: if false; // Functions only
    }

    match /{path=**}/badges/{badgeId} {
      allow read: if true;
      allow write: if false; // Functions only
    }

    match /siteSettings/{settingId} {
      allow read: if true; // Public read for theme settings
      allow create: if false; // Use updateSiteSettingsViaFunction
      allow update: if false; // Use updateSiteSettingsViaFunction
      allow delete: if false; // Manual process only
    }

    match /posts/{postId} {
      allow read: if true; // Public read access
      allow create: if false; // Use createPostViaFunction
      allow update: if false; // Use updatePostViaFunction
      allow delete: if false; // Use deletePostViaFunction (admin only)

      match /replies/{replyId} {
        allow read: if true; // Public read access
        allow create: if false; // Use createReplyViaFunction
        allow update: if false; // Use updateReplyViaFunction
        allow delete: if false; // Use deleteReplyViaFunction (admin only)
      }
    }

    // Maintenance / migration kill-switch flag.
    //
    // Triggers and the set-maintenance.js CLI script use the firebase-admin
    // SDK and bypass these rules entirely, which is how the flag actually
    // gets flipped during a migration. The rules below exist as a
    // defense-in-depth lock for the unlikely case that something tries to
    // read or write `system/maintenance` from the App's client SDK — never
    // currently happens, but this keeps it locked down.
    //
    // Admin status is sourced from the player document's `admin` boolean
    // field (this codebase doesn't use Firebase Auth custom token claims),
    // so we read the player doc to check it.
    function isAdmin() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/players/$(request.auth.uid))
        && get(/databases/$(database)/documents/players/$(request.auth.uid)).data.admin == true;
    }

    match /system/{document} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}